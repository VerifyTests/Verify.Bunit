<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageTags>BUnit, Verify, Blazor</PackageTags>
    <Description>Extends Verify (https://github.com/VerifyTests/Verify) to allow Blazor component verification via BUnit.</Description>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="../build.props" PackagePath="buildTransitive\Verify.Bunit.props" />
    <Content Include="../Verify.Bunit.AfterMicrosoftNetSdk.props" PackagePath="buildTransitive\Verify.Bunit.AfterMicrosoftNetSdk.props" />
    <Content Include="../build.targets" PackagePath="buildMultiTargeting\Verify.Bunit.targets" />
    <Content Include="../build.targets" PackagePath="build\Verify.Bunit.targets" />
    <PackageReference Include="bunit" />
    <PackageReference Include="ProjectDefaults" PrivateAssets="all" />
    <PackageReference Include="Verify" />
    <PackageReference Include="Microsoft.Sbom.Targets" PrivateAssets="all" Condition="'$(CI)' == 'true'" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Tests" PublicKey="" />
  </ItemGroup>
</Project>